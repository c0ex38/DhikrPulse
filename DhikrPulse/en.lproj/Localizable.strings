/* Esma Meanings (First 15) */
"esma_mean_1" = "The one and only God, without equal, free from all imperfections.";
"esma_mean_2" = "The One who shows mercy and compassion to all creation in this world.";
"esma_mean_3" = "The One who grants infinite grace, favor, and bounty to believers in the Hereafter.";
"esma_mean_4" = "The Owner of all domains, whose sovereignty and dominion are eternal.";
"esma_mean_5" = "The One free from all shortcomings, possessing all attributes of perfection.";
"esma_mean_6" = "The One who delivers His servants to peace and greets His blessed servants in paradise.";
"esma_mean_7" = "The One who illuminates hearts with faith, granting security and peace to His creation.";
"esma_mean_8" = "The One who oversees and protects all creatures.";
"esma_mean_9" = "The Majestic, the Almighty who is victorious over all things.";
"esma_mean_10" = "The Compeller, possessing majesty and power. Able to execute His will.";
"esma_mean_11" = "The Supreme, without equal in greatness.";
"esma_mean_12" = "The Creator who brings everything out of nothing into existence.";
"esma_mean_13" = "The Evolver who creates everything flawlessly and harmoniously.";
"esma_mean_14" = "The Fashioner who forms and designs all beings differently.";
"esma_mean_15" = "The Great Forgiver who covers sins and forgives immensely.";
